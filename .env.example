# Nazwa aplikacji. Moze byc PartyMaker.
APP_NAME=PartyMaker

# Tryb aplikacji. Lokalnie wpisz local.
APP_ENV=local

# Klucz aplikacji. Nie wpisuj recznie, uruchom: php artisan key:generate
APP_KEY=

# Pokazuje bledy w przegladarce. Lokalnie moze byc true.
APP_DEBUG=true

# Adres aplikacji. Lokalnie zwykle: http://127.0.0.1:8000
APP_URL=http://127.0.0.1:8000

# Adres do plikow CSS/JS. Lokalnie zwykle taki sam jak APP_URL.
ASSET_URL=http://127.0.0.1:8000

# Czy ciasteczka sesji wymagaja HTTPS. Lokalnie zwykle false.
SESSION_SECURE_COOKIE=false

# Glowny jezyk aplikacji. Dla polskiego wpisz pl.
APP_LOCALE=pl

# Jezyk awaryjny, gdy brakuje tlumaczenia.
APP_FALLBACK_LOCALE=en

# Jezyk danych testowych.
APP_FAKER_LOCALE=en_US

# Sposob wlaczania trybu przerwy technicznej. Zwykle file.
APP_MAINTENANCE_DRIVER=file

# Liczba rund szyfrowania hasla. Zwykle 12.
BCRYPT_ROUNDS=12

# Gdzie zapisywac logi. Zwykle stack.
LOG_CHANNEL=stack

# Ktory plik logow uzywac. Zwykle single.
LOG_STACK=single

# Kanal dla ostrzezen o przestarzalym kodzie. Zwykle null.
LOG_DEPRECATIONS_CHANNEL=null

# Poziom logow. Lokalnie zwykle debug.
LOG_LEVEL=debug

# Typ bazy danych. W tym projekcie zwykle mysql.
DB_CONNECTION=mysql

# Adres bazy danych. Lokalnie zwykle 127.0.0.1.
DB_HOST=127.0.0.1

# Port MySQL. Zwykle 3306.
DB_PORT=3306

# Nazwa bazy danych.
DB_DATABASE=partymaker_test

# Uzytkownik bazy danych.
DB_USERNAME=root

# Haslo do bazy danych. Gdy nie ma hasla, zostaw puste.
DB_PASSWORD=

# Gdzie trzymac sesje. Lokalnie moze byc file.
SESSION_DRIVER=file

# Ile minut trwa sesja.
SESSION_LIFETIME=120

# Czy szyfrowac dane sesji.
SESSION_ENCRYPT=false

# Sciezka ciasteczka sesji. Zwykle /.
SESSION_PATH=/

# Domena ciasteczka sesji. Lokalnie zwykle null albo puste.
SESSION_DOMAIN=null

# Nadawanie zdarzen realtime. Dla Reverb wpisz reverb.
BROADCAST_CONNECTION=reverb

# Dysk plikow. Lokalnie zwykle local.
FILESYSTEM_DISK=local

# Kolejka zadan. Lokalnie moze byc sync albo database.
QUEUE_CONNECTION=sync

# Cache aplikacji. Lokalnie moze byc file.
CACHE_STORE=file

# Adres Memcached, jezeli jest uzywany.
MEMCACHED_HOST=127.0.0.1

# Klient Redis.
REDIS_CLIENT=phpredis

# Adres Redis.
REDIS_HOST=127.0.0.1

# Haslo Redis. Gdy nie ma hasla, wpisz null albo zostaw puste.
REDIS_PASSWORD=null

# Port Redis. Zwykle 6379.
REDIS_PORT=6379

# Sposob wysylania maili. Np. smtp albo log.
MAIL_MAILER=smtp

# Host poczty SMTP.
MAIL_HOST=smtp.gmail.com

# Port poczty SMTP. Dla Gmail zwykle 587.
MAIL_PORT=587

# Login do poczty.
MAIL_USERNAME=

# Haslo albo haslo aplikacji do poczty.
MAIL_PASSWORD=

# Adres nadawcy maili.
MAIL_FROM_ADDRESS=

# Nazwa nadawcy maili.
MAIL_FROM_NAME="${APP_NAME}"

# Klucz AWS, jezeli uzywasz S3.
AWS_ACCESS_KEY_ID=

# Sekret AWS, jezeli uzywasz S3.
AWS_SECRET_ACCESS_KEY=

# Region AWS.
AWS_DEFAULT_REGION=us-east-1

# Nazwa bucketu S3.
AWS_BUCKET=

# Tryb zgodnosci S3. Zwykle false.
AWS_USE_PATH_STYLE_ENDPOINT=false

# Nazwa aplikacji widoczna dla Vite.
VITE_APP_NAME="${APP_NAME}"

# ID aplikacji Google do logowania.
GOOGLE_CLIENT_ID=

# Sekret aplikacji Google do logowania.
GOOGLE_CLIENT_SECRET=

# Adres powrotu po logowaniu Google.
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# ID aplikacji Facebook do logowania.
FACEBOOK_CLIENT_ID=

# Sekret aplikacji Facebook do logowania.
FACEBOOK_CLIENT_SECRET=

# Adres powrotu po logowaniu Facebook.
FACEBOOK_REDIRECT_URI="${APP_URL}/auth/facebook/callback"

# ID aplikacji Reverb.
REVERB_APP_ID=

# Klucz aplikacji Reverb.
REVERB_APP_KEY=

# Sekret aplikacji Reverb.
REVERB_APP_SECRET=

# Host Reverb. Lokalnie zwykle localhost.
REVERB_HOST="localhost"

# Port Reverb. Lokalnie zwykle 8080.
REVERB_PORT=8080

# Schemat Reverb. Lokalnie zwykle http.
REVERB_SCHEME=http

# Klucz Reverb dla frontendu. Zwykle taki sam jak REVERB_APP_KEY.
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"

# Host Reverb dla frontendu. Zwykle taki sam jak REVERB_HOST.
VITE_REVERB_HOST="${REVERB_HOST}"

# Port Reverb dla frontendu. Zwykle taki sam jak REVERB_PORT.
VITE_REVERB_PORT="${REVERB_PORT}"

# Schemat Reverb dla frontendu. Zwykle taki sam jak REVERB_SCHEME.
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Token SMSAPI do wysylania SMS.
SMSAPI_AUTH_TOKEN=

# Tryb testowy SMSAPI. Lokalnie najlepiej true.
SMSAPI_TEST_MODE=true

# Klucz API do modelu AI.
LLM_API_KEY=

# Adres API modelu AI.
LLM_BASE_URL=https://api.deepseek.com

# Nazwa modelu AI.
LLM_MODEL=deepseek-v4-flash
